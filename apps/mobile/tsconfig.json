{
  "compilerOptions": {
    "target": "ESNext",
    "jsx": "react-native",
    "strict": true,
    "allowJs": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@expo/vector-icons": ["./node_modules/expo/node_modules/@expo/vector-icons"],
      "@expo/vector-icons/*": ["./node_modules/expo/node_modules/@expo/vector-icons/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "extends": "expo/tsconfig.base"
}
